<% if @ride_requests %>
  <%= render "home/active_ride_requests" %>
<% else %>
  <section class="space-y-6">
    <div class="surface-card">
      <h1 class="text-3xl font-semibold tracking-tight text-primary">Welcome</h1>

      <% if user_signed_in? %>
        <p class="mt-3 text-secondary">Signed in as <%= current_identity.email %></p>
        <%= button_to "Sign out",
                      destroy_identity_session_path,
                      method: :delete,
                      class: "primary-btn mt-5" %>
      <% else %>
        <div class="mt-5 border-t border-primary/10 pt-5">
          <%= render "shared/auth/sign_in_form",
                     resource: Identity.new,
                     resource_name: :identity %>
        </div>
      <% end %>
    </div>
  </section>
<% end %>
