<section class="surface-card">
  <div class="mb-6">
    <h1 class="text-3xl font-semibold tracking-tight text-primary"><%= @header_text %></h1>
  </div>

  <% form = ActionView::Helpers::FormBuilder.new("ride_request", @ride_request, self, {}) %>
  <%= render RideRequestMutate::FormStep5Component.new(
    form:,
    total_steps: RideRequestMutateConcerns::HasMutateRideRequestForm::FORM_STEP_COUNT,
    ride_request: @ride_request,
    show_step_header: false
  ) %>

  <%= render "shared/action_buttons", cancel_path: ride_requests_path, readonly: true, back_text: "Back to ride requests" %>
</section>
