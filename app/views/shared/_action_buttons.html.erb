<% cancel_path = local_assigns.fetch(:cancel_path, users_path) %>
<div class="flex items-center justify-end gap-3">
  <%= link_to "Cancel", cancel_path, class: "text-sm font-semibold text-forest-900/70 transition hover:text-forest-900 active:text-forest-900/80" %>
  <% if @show_send_login_link_button %>
    <%= button_to "Send Login Link",
      send_login_link_user_path(id: @target_user.id),
      method: :post,
      disabled: @send_login_link_button_disabled,
      class: "rounded-full border border-forest-900/40 px-4 py-2 text-xs font-semibold uppercase tracking-wide text-forest-900 transition hover:border-forest-900 hover:text-forest-900/80" %>
  <% end %>
  <button type="submit"
          form="<%= form_id %>"
          class="rounded-full bg-forest-900 px-4 py-2 text-xs font-semibold uppercase tracking-wide text-fog-100 transition hover:bg-forest-800 active:bg-forest-900/90">
    <%= @submit_text %>
  </button>
</div>
