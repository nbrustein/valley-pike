<% readonly = local_assigns.fetch(:readonly, false) %>
<% if readonly %>
  <div class="flex items-center gap-2 text-sm text-primary">
    <% if checked %>
      <i class="fa-solid fa-square-check text-primary/70"></i>
    <% else %>
      <i class="fa-regular fa-square text-primary/50"></i>
    <% end %>
    <%= label %>
  </div>
<% else %>
  <label class="flex items-center gap-2 text-sm text-primary" for="<%= input_id %>">
    <input type="checkbox" name="<%= name %>" id="<%= input_id %>" value="<%= value %>" <%= "checked" if checked %>>
    <%= label %>
  </label>
<% end %>
