<% readonly = local_assigns.fetch(:readonly, false) %>
<div>
  <% if readonly %>
    <p class="block text-sm font-semibold text-forest-900">Full Name</p>
    <p class="mt-2 text-sm text-forest-900"><%= @full_name %></p>
  <% else %>
    <%= form.label :full_name, "Full Name", class: "block text-sm font-semibold text-forest-900" %>
    <%= form.text_field :full_name, value: @full_name, required: true, class: "mt-2 w-full rounded-lg border border-forest-900/20 bg-white px-3 py-2 text-sm text-forest-900", data: {full_name_input: true} %>
  <% end %>
</div>
