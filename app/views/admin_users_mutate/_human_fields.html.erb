<% readonly = local_assigns.fetch(:readonly, false) %>
<%= render Shared::TextFieldComponent.new(field: :email, label: "Email", value: @email, form:, readonly:, type: :email, required: true) %>
<%= render Shared::TextFieldComponent.new(field: :full_name, label: "Full Name", value: @full_name, form:, readonly:, required: true, data: {full_name_input: true}) %>
<%= render Shared::TextFieldComponent.new(field: :preferred_name, label: "Preferred Name", value: @preferred_name, form:, readonly:, required: true, data: {preferred_name_input: true}) %>
<%= render Shared::TextFieldComponent.new(field: :phone, label: "Phone", value: @phone, form:, readonly:, type: :phone) %>
