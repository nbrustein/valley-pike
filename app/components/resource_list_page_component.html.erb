<section class="surface-card">
  <div class="flex flex-wrap items-center justify-between gap-3">
    <h1 class="text-3xl font-semibold tracking-tight text-primary"><%= @title %></h1>
    <% if @create_path %>
      <%= link_to "Create", @create_path, class: "rounded-full bg-primary px-4 py-2 text-xs font-semibold uppercase tracking-wide text-surface transition hover:bg-primary/85" %>
    <% end %>
  </div>

  <%= content %>
</section>
