<section class="surface-card">
  <div class="flex flex-wrap items-center justify-between gap-3">
    <h1 class="text-3xl font-semibold tracking-tight text-forest-900"><%= @title %></h1>
    <% if @create_path %>
      <%= link_to "Create", @create_path, class: "rounded-full bg-forest-900 px-4 py-2 text-xs font-semibold uppercase tracking-wide text-fog-100 transition hover:bg-forest-800" %>
    <% end %>
  </div>

  <%= content %>
</section>
