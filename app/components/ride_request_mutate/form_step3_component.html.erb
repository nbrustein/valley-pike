<div class="space-y-5">
  <div>
    <p class="text-base font-semibold text-primary">3 of 5: Private Information</p>
    <p class="mt-1 text-sm text-primary/70">This information will only be sent to the driver who accepts the ride</p>
  </div>

  <%= render pick_up_address_field %>

  <div>
    <p class="text-sm font-semibold text-primary">Private Ride Notes</p>
    <p class="mt-1 text-sm text-primary/70">These notes will be sent to the assigned driver. Consider including:</p>
    <ul class="mt-1 list-disc pl-5 text-sm text-primary/70 space-y-0.5">
      <li>The rider's name and contact information</li>
      <li>Any other information the driver may need that was not included in the public description</li>
    </ul>
    <%= render ride_description_private_field %>
  </div>
</div>
