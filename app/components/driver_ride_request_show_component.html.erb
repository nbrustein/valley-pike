<section>
  <div class="rounded-2xl border border-primary/10 bg-white/80 p-4 shadow-sm backdrop-blur sm:p-6 space-y-5">
    <div>
      <h1 class="text-2xl font-semibold tracking-tight text-primary"><%= @ride_request.short_description %></h1>
      <p class="mt-1 text-sm text-secondary"><%= @ride_request.organization.name %></p>
    </div>

    <div class="grid gap-4 sm:grid-cols-2">
      <div>
        <p class="text-sm font-medium text-secondary">Date</p>
        <p class="text-primary"><%= formatted_date %></p>
      </div>

      <% if @ride_request.appointment_time.present? %>
        <div>
          <p class="text-sm font-medium text-secondary">Appointment Time</p>
          <p class="text-primary"><%= @ride_request.appointment_time %></p>
        </div>
      <% end %>

      <% if formatted_gender_preference %>
        <div>
          <p class="text-sm font-medium text-secondary">Requirements</p>
          <p class="text-primary"><%= formatted_gender_preference %></p>
        </div>
      <% end %>

      <div>
        <p class="text-sm font-medium text-secondary">Status</p>
        <p class="text-primary"><%= status_label %></p>
      </div>

    </div>

    <% if @ride_request.pick_up_address.present? %>
      <div>
        <p class="text-sm font-medium text-secondary">Pick Up</p>
        <p class="text-primary"><%= @ride_request.pick_up_address.name %></p>
        <p class="text-sm text-secondary"><%= format_address(@ride_request.pick_up_address) %></p>
      </div>
    <% end %>

    <% if @ride_request.destination_address.present? %>
      <div>
        <p class="text-sm font-medium text-secondary">Destination</p>
        <p class="text-primary"><%= @ride_request.destination_address.name %></p>
        <p class="text-sm text-secondary"><%= format_address(@ride_request.destination_address) %></p>
      </div>
    <% end %>

    <% if @ride_request.ride_description_public.present? %>
      <div>
        <p class="text-sm font-medium text-secondary">Ride Description</p>
        <p class="text-primary whitespace-pre-line"><%= @ride_request.ride_description_public %></p>
      </div>
    <% end %>

    <% if @ride_request.driver_notes.present? %>
      <div>
        <p class="text-sm font-medium text-secondary">Driver Notes</p>
        <p class="text-primary whitespace-pre-line"><%= @ride_request.driver_notes %></p>
      </div>
    <% end %>

    <div class="border-t border-primary/10 pt-4">
      <p class="text-sm font-medium text-secondary mb-2">Contact</p>
      <div class="grid gap-2 sm:grid-cols-3">
        <% if @ride_request.contact_full_name.present? %>
          <p class="text-primary"><%= @ride_request.contact_full_name %></p>
        <% end %>
        <% if @ride_request.contact_phone.present? %>
          <p class="text-primary"><%= @ride_request.contact_phone %></p>
        <% end %>
        <% if @ride_request.contact_email.present? %>
          <p class="text-primary"><%= @ride_request.contact_email %></p>
        <% end %>
      </div>
    </div>

    <div class="flex items-center justify-end">
      <%= link_to "Back", root_path,
            class: "text-sm font-semibold text-primary/70 transition hover:text-primary active:text-primary/80" %>
    </div>
  </div>
</section>
