<section class="space-y-4">
  <h1 class="text-3xl font-semibold tracking-tight text-primary">Active Rides</h1>

  <% if @ride_requests.empty? %>
    <p class="text-secondary">No ride requests available.</p>
  <% else %>
    <div class="space-y-3">
      <% @ride_requests.each do |ride_request| %>
        <%= link_to driver_ride_request_path(id: ride_request.id),
              class: "surface-card block transition hover:shadow-md" do %>
          <div class="flex items-start justify-between gap-4">
            <div class="min-w-0 flex-1">
              <h2 class="text-lg font-semibold text-primary truncate"><%= ride_request.short_description %></h2>
              <p class="mt-1 text-sm text-secondary"><%= ride_request.organization.name %></p>
              <% if ride_request.destination_address.present? %>
                <p class="mt-1 text-sm text-secondary">
                  <%= ride_request.destination_address.name %>, <%= ride_request.destination_address.city %>
                </p>
              <% end %>
            </div>
            <div class="shrink-0 text-right">
              <p class="text-sm font-medium text-primary"><%= ride_request.date.strftime("%b %-d, %Y") %></p>
            </div>
          </div>
        <% end %>
      <% end %>
    </div>
  <% end %>
</section>
