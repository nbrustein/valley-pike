<div>
  <% if @readonly %>
    <p class="block text-sm font-semibold text-forest-900"><%= @label %></p>
    <p class="mt-2 text-sm text-forest-900"><%= @value %></p>
  <% else %>
    <fieldset class="mui-fieldset">
      <legend class="mui-legend"><%= @label %><% if @required %> *<% end %></legend>
      <%= @form.public_send(field_method, @field, value: @value, required: @required, data: @data, placeholder: @placeholder, class: "mui-fieldset-input") %>
    </fieldset>
    <% if @description %>
      <p class="mt-1 text-xs text-forest-900/60"><%= @description %></p>
    <% end %>
  <% end %>
</div>
