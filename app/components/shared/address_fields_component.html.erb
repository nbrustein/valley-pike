<% if @readonly %>
  <div>
    <p class="block text-sm font-semibold text-primary"><%= @label %></p>
    <p class="mt-2 text-sm text-primary"><%= safe_join(formatted_address_lines, tag.br) %></p>
  </div>
<% else %>
  <fieldset class="rounded-lg border border-primary/10 px-4 pb-4 pt-3">
    <legend class="px-1 text-sm font-semibold text-primary"><%= @label %></legend>
    <div class="space-y-4">
      <%= render name_field %>
      <%= render street_address_field %>
      <div class="grid grid-cols-2 gap-4">
        <%= render city_field %>
        <%= render state_field %>
      </div>
    </div>
  </fieldset>
<% end %>
