<fieldset class="rounded-lg border border-forest-900/10 px-4 pb-4 pt-3">
  <legend class="px-1 text-sm font-semibold text-forest-900"><%= @label %></legend>
  <div class="space-y-4">
    <%= render name_field %>
    <%= render street_address_field %>
    <div class="grid grid-cols-2 gap-4">
      <%= render city_field %>
      <%= render state_field %>
    </div>
  </div>
</fieldset>
