<div>
  <% if @readonly %>
    <% if @label %>
      <p class="block text-sm font-semibold text-primary"><%= @label %></p>
    <% end %>
    <p class="mt-2 text-sm text-primary"><%= @value %></p>
  <% else %>
    <fieldset class="mui-fieldset">
      <% if @label %>
        <legend class="mui-legend"><%= @label %><% if @required %> *<% end %></legend>
      <% end %>
      <%= @form.text_area @field, value: @value, required: @required, placeholder: @placeholder, rows: @rows, class: "mui-fieldset-input" %>
    </fieldset>
    <% if @description %>
      <p class="mt-1 text-xs text-primary/60"><%= @description %></p>
    <% end %>
  <% end %>
</div>
